{
  "name": "@agentflowx/bot-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentFlow Bot Platform — Matrix bots without the Matrix headache.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentFlowX/bot-sdk-typescript.git"
  },
  "keywords": ["matrix", "bot", "agentflow", "sdk", "chat"],
  "homepage": "https://docs.agentflow.website/bots"
}
